{
  "$defs": {
    "artifact": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "pattern": "^artifact-[a-z0-9][a-z0-9-]*$",
          "type": "string"
        },
        "length_bytes": {
          "minimum": 1,
          "type": "integer"
        },
        "locator": {
          "minLength": 1,
          "type": "string"
        },
        "media_type": {
          "minLength": 1,
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "url": {
          "format": "uri",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "locator",
        "media_type",
        "url"
      ],
      "type": "object"
    },
    "case": {
      "additionalProperties": false,
      "properties": {
        "artifacts": {
          "items": {
            "$ref": "#/$defs/artifact"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "content_instance": {
          "minProperties": 1,
          "type": "object"
        },
        "identity": {
          "additionalProperties": false,
          "properties": {
            "maker": {
              "minLength": 1,
              "type": "string"
            },
            "title": {
              "minLength": 1,
              "type": "string"
            },
            "version_scope": {
              "minLength": 1,
              "type": "string"
            }
          },
          "required": [
            "maker",
            "title",
            "version_scope"
          ],
          "type": "object"
        },
        "scope_exclusions": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        },
        "scope_inclusions": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "source_anchor_id": {
          "enum": [
            "source-anchor-01",
            "source-anchor-02",
            "source-anchor-03",
            "source-anchor-04"
          ]
        },
        "source_records": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "evidence_kind": {
                "enum": [
                  "source_fact",
                  "project_measurement",
                  "source_underdetermined"
                ]
              },
              "locator": {
                "minLength": 1,
                "type": "string"
              },
              "record_id": {
                "pattern": "^record-[a-z0-9][a-z0-9-]*$",
                "type": "string"
              },
              "statement": {
                "minLength": 1,
                "type": "string"
              }
            },
            "required": [
              "evidence_kind",
              "locator",
              "record_id",
              "statement"
            ],
            "type": "object"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        }
      },
      "required": [
        "artifacts",
        "content_instance",
        "identity",
        "scope_exclusions",
        "scope_inclusions",
        "source_anchor_id",
        "source_records"
      ],
      "type": "object"
    }
  },
  "$id": "https://github.com/onovich/Game-Primitives/blob/main/research/calibration-tests/logic-pilot/schema/source-packet.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "artifact_version": {
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "type": "string"
    },
    "cases": {
      "allOf": [
        {
          "contains": {
            "properties": {
              "source_anchor_id": {
                "const": "source-anchor-01"
              }
            },
            "required": [
              "source_anchor_id"
            ]
          }
        },
        {
          "contains": {
            "properties": {
              "source_anchor_id": {
                "const": "source-anchor-02"
              }
            },
            "required": [
              "source_anchor_id"
            ]
          }
        },
        {
          "contains": {
            "properties": {
              "source_anchor_id": {
                "const": "source-anchor-03"
              }
            },
            "required": [
              "source_anchor_id"
            ]
          }
        },
        {
          "contains": {
            "properties": {
              "source_anchor_id": {
                "const": "source-anchor-04"
              }
            },
            "required": [
              "source_anchor_id"
            ]
          }
        }
      ],
      "items": {
        "$ref": "#/$defs/case"
      },
      "maxItems": 4,
      "minItems": 4,
      "type": "array",
      "uniqueItems": true
    },
    "packet_id": {
      "const": "source-packet-logic-001"
    },
    "protocol_version": {
      "const": "0.3.0"
    },
    "run_id": {
      "const": "logic-001"
    },
    "source_freeze_date": {
      "format": "date",
      "type": "string"
    }
  },
  "required": [
    "$schema",
    "artifact_version",
    "cases",
    "packet_id",
    "protocol_version",
    "run_id",
    "source_freeze_date"
  ],
  "title": "Game Primitives Logic Pilot Source Packet",
  "type": "object"
}
