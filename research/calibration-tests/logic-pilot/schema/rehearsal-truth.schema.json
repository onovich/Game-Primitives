{
  "$id": "https://github.com/onovich/Game-Primitives/blob/main/research/calibration-tests/logic-pilot/schema/rehearsal-truth.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "artifact_version": {
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "type": "string"
    },
    "expected_responses": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "item_id": {
            "pattern": "^item-[a-z0-9]{8,16}$",
            "type": "string"
          },
          "sum": {
            "type": "integer"
          },
          "token": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "item_id",
          "sum",
          "token"
        ],
        "type": "object"
      },
      "maxItems": 2,
      "minItems": 2,
      "type": "array",
      "uniqueItems": true
    },
    "input_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "protocol_version": {
      "const": "0.3.0"
    },
    "run_id": {
      "const": "logic-000"
    },
    "shuffle_seed": {
      "pattern": "^[0-9a-f]{32}$",
      "type": "string"
    },
    "truth_id": {
      "const": "truth-rehearsal-001"
    }
  },
  "required": [
    "$schema",
    "artifact_version",
    "expected_responses",
    "input_sha256",
    "protocol_version",
    "run_id",
    "shuffle_seed",
    "truth_id"
  ],
  "title": "Game Primitives Logic Pilot Procedural Rehearsal Truth",
  "type": "object"
}
